---
import { profile } from "../lib/profile.ts";

const links = [
  { href: "/", label: "Home" },
  { href: "/content", label: "Content" },
  { href: "/about", label: "About" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<nav class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${profile.name} — home`}>
      <svg
        class="logo"
        viewBox="0 0 54 40"
        role="img"
        aria-hidden="true"
        focusable="false"
      >
        <defs>
          <linearGradient id="nnPeakA" x1="0" y1="1" x2="1" y2="0">
            <stop offset="0" stop-color="var(--brand)" />
            <stop offset="1" stop-color="var(--brand-2)" />
          </linearGradient>
          <linearGradient id="nnPeakB" x1="0" y1="1" x2="1" y2="0">
            <stop offset="0" stop-color="var(--brand-2)" />
            <stop offset="1" stop-color="var(--accent)" />
          </linearGradient>
        </defs>
        <path
          d="M7 37 V11 L25 37 V11"
          fill="none"
          stroke="url(#nnPeakA)"
          stroke-width="5.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M22 37 V11 L40 37 V11"
          fill="none"
          stroke="url(#nnPeakB)"
          stroke-width="5.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
    <div class="nav-right">
      <ul class="nav-links">
        {
          links.map((l) => (
            <li>
              <a href={l.href} class={isActive(l.href) ? "active" : ""}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <slot />
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand:hover {
    text-decoration: none;
  }
  .logo {
    height: 30px;
    width: auto;
    display: block;
    transition: transform 0.15s ease;
  }
  .brand:hover .logo {
    transform: translateY(-1px) scale(1.04);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .nav-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    color: var(--text-muted);
    font-weight: 600;
  }
  .nav-links a.active,
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
