---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../lib/profile.ts";
import {
  siGithub,
  siGooglescholar,
  siSessionize,
  siSpeakerdeck,
  siSlideshare,
  siHuggingface,
  siDevdotto,
  siInstagram,
  siSubstack,
} from "simple-icons";

// Hand-coded glyphs for brands not in Simple Icons (trademark-removed / absent).
const LINKEDIN =
  "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z";
const ENVELOPE =
  "M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0zM22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0z";
const DOCUMENT =
  "M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875m9.586 6.696A5.23 5.23 0 0 0 14.25 5.25v-.34a9.768 9.768 0 0 1 4.968 4.968h-.34a5.23 5.23 0 0 1-3.667-1.682";

// Per-host presentation: brand label, icon path, brand hex color.
const BRANDS: Record<string, { label: string; path: string; hex: string }> = {
  "github.com": { label: "GitHub", path: siGithub.path, hex: "6e7681" },
  "linkedin.com": { label: "LinkedIn", path: LINKEDIN, hex: "0A66C2" },
  "scholar.google.com": {
    label: "Google Scholar",
    path: siGooglescholar.path,
    hex: "4285F4",
  },
  "sessionize.com": {
    label: "Sessionize",
    path: siSessionize.path,
    hex: "1AB394",
  },
  "speakerdeck.com": {
    label: "Speaker Deck",
    path: siSpeakerdeck.path,
    hex: "009287",
  },
  "slideshare.net": {
    label: "SlideShare",
    path: siSlideshare.path,
    hex: "008ED2",
  },
  "huggingface.co": {
    label: "Hugging Face",
    path: siHuggingface.path,
    hex: "FFD21E",
  },
  "dev.to": { label: "DEV", path: siDevdotto.path, hex: "6e7681" },
  "instagram.com": {
    label: "Instagram",
    path: siInstagram.path,
    hex: "E4405F",
  },
  "substack.com": { label: "Substack", path: siSubstack.path, hex: "FF6719" },
  "aka.ms": { label: "Newsletter", path: ENVELOPE, hex: "8B5CF6" },
  "patents.google.com": {
    label: "Google Patents",
    path: DOCUMENT,
    hex: "4285F4",
  },
};

const FALLBACK = { label: "", path: DOCUMENT, hex: "6e7681" };

function brandFor(url: string) {
  try {
    const host = new URL(url).hostname.replace(/^www\./, "");
    const b = BRANDS[host];
    return b ?? { ...FALLBACK, label: host };
  } catch {
    return { ...FALLBACK, label: url };
  }
}

const links = profile.sameAs.map((url) => ({ url, ...brandFor(url) }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  description: profile.bio,
  jobTitle: profile.headline,
  address: profile.location,
  url: "https://nitya.github.io/about",
  sameAs: profile.sameAs,
};
---

<BaseLayout
  title={`About — ${profile.name}`}
  description={profile.bio}
  jsonLd={jsonLd}
>
  <section class="about">
    <h1 class="gradient-text">About</h1>
    <p class="headline">{profile.headline}</p>
    <p class="loc">📍 {profile.location}</p>
    <p class="bio">{profile.bio}</p>

    <h2>Find me online</h2>
    <ul class="links">
      {
        links.map((l) => (
          <li>
            <a
              class="badge"
              href={l.url}
              target="_blank"
              rel="noopener me"
              style={`--bc:#${l.hex}`}
            >
              <svg
                class="ic"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={l.path} />
              </svg>
              <span>{l.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 720px;
  }
  .about h1 {
    font-size: 2.6rem;
    margin: 0 0 0.4rem;
  }
  .headline {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
  }
  .loc {
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }
  .bio {
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .about h2 {
    margin-top: 2.5rem;
    font-size: 1.3rem;
  }
  .links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-weight: 600;
    background: var(--bg-elev);
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s,
      transform 0.15s;
  }
  .badge .ic {
    width: 18px;
    height: 18px;
    color: var(--bc);
    flex: 0 0 auto;
  }
  .badge:hover {
    color: var(--bc);
    border-color: var(--bc);
    background: color-mix(in srgb, var(--bc) 12%, var(--bg-elev));
    text-decoration: none;
    transform: translateY(-1px);
  }
</style>
